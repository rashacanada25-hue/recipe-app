# העתיקי ל־.env והשלימי את הערכים (הקובץ .env לא נשמר ב־Git)
MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/recipe_db?retryWrites=true&w=majority

# Vercel AI Gateway — ל־POST /recipes/generate
# https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=
# אופציונלי:
# AI_GATEWAY_URL=https://ai-gateway.vercel.sh/v1
# AI_GATEWAY_MODEL=openai/gpt-4o-mini
